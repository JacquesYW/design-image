{
  "name": "@design-platform/image",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://jacquesyw.github.io/design-image/",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "start": "vite --host",
    "build": "vite build",
    "buildtsc": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false"
  },
  "lint-staged": {
    "*": "prettier --write --cache --ignore-unknown",
    "*.{ts,tsx}": "eslint --cache --fix --ignore-pattern '*.svg'"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.5",
    "@hello-pangea/dnd": "^16.5.0",
    "@scena/guides": "^0.29.2",
    "antd": "^5.15.4",
    "axios": "^1.7.2",
    "classnames": "^2.3.2",
    "copy-to-clipboard": "^3.3.3",
    "downloadjs": "^1.4.7",
    "gsap": "^3.12.4",
    "html-to-image": "^1.11.11",
    "immer": "^10.0.2",
    "less": "^4.2.0",
    "lodash": "^4.17.21",
    "moveable": "^0.51.1",
    "overlap-area": "^1.1.0",
    "parchment": "^1.1.4",
    "quill": "2.0.0-beta.0",
    "quill-delta": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.2",
    "selecto": "^1.26.0",
    "upng-js": "^2.1.0",
    "use-eye-dropper": "^1.6.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/downloadjs": "^1.4.6",
    "@types/lodash": "^4.14.197",
    "@types/node": "^20.14.2",
    "@types/quill": "^2.0.13",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/upng-js": "^2.1.5",
    "@types/uuid": "^9.0.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "4.0.4",
    "eslint": "^8.45.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "lint-staged": "^15.2.5",
    "postcss-preset-env": "^9.1.1",
    "prettier": "^3.3.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.4.5",
    "unplugin-auto-import": "^0.16.6",
    "vite": "^4.4.9"
  }
}